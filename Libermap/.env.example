# Libermap - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

# Servidor
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true

# Banco de Dados
DB_HOST=db
DB_PORT=5432
DB_NAME=libermap
DB_USER=libermap
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Mapa
MAP_DEFAULT_LAT=-14.79
MAP_DEFAULT_LNG=-39.27
MAP_DEFAULT_ZOOM=14
MAP_TILE_PROVIDER=openstreetmap

# Licença
LICENSE_SERVER_URL=https://license.libernet.com.br
LICENSE_KEY=

# Segurança
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
